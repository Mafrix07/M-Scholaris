<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>

<VBox maxWidth="230.0" minWidth="230.0" prefWidth="230.0" styleClass="sidebar" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.SidebarController">
   <children>
      <!-- LOGO SECTION -->
      <VBox spacing="10.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Logo.png" />
                     </image>
                  </ImageView>
                  <VBox>
                     <children>
                        <Label styleClass="sidebar-logo-text" text="SCHOLARIS" />
                        <Label styleClass="sidebar-subtitle" text="MANAGEMENT" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
         </padding>
      </VBox>

      <Label styleClass="text-faint" text="NAVIGATION PRINCIPALE">
         <VBox.margin>
            <Insets left="20.0" bottom="5.0" />
         </VBox.margin>
      </Label>

      <!-- NAVIGATION : Remplit l'espace vertical -->
      <VBox fx:id="navContainer" spacing="5.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets left="10.0" right="10.0" />
         </padding>
         
         <HBox fx:id="navAdminDashboard" onMouseClicked="#handleNavAdminDashboard" styleClass="sidebar-item">
            <children><Label text="🏠  Tableau de bord" /></children>
         </HBox>
         <HBox fx:id="navAdminEtudiants" onMouseClicked="#handleNavAdminEtudiants" styleClass="sidebar-item">
            <children><Label text="👤  Gestion Étudiants" /></children>
         </HBox>
         <HBox fx:id="navAdminSaisie" onMouseClicked="#handleNavSaisieNotes" styleClass="sidebar-item">
            <children><Label text="✏️  Saisie des Notes" /></children>
         </HBox>
         <HBox fx:id="navAdminBulletins" onMouseClicked="#handleNavAdminBulletins" styleClass="sidebar-item">
            <children><Label text="📄  Bulletins Scolaires" /></children>
         </HBox>
         
         <Region fx:id="adminSeparator" prefHeight="20.0" />
         <Label fx:id="adminLabel" styleClass="text-faint" text="CONFIGURATION">
            <VBox.margin><Insets left="10.0" /></VBox.margin>
         </Label>

         <HBox fx:id="navAdminUsers" onMouseClicked="#handleNavAdminUsers" styleClass="sidebar-item">
            <children><Label text="👥  Utilisateurs" /></children>
         </HBox>
         <HBox fx:id="navAdminParams" onMouseClicked="#handleNavAdminParams" styleClass="sidebar-item">
            <children><Label text="⚙️  Paramètres" /></children>
         </HBox>

         <!-- Teacher items -->
         <HBox fx:id="navTeacherDashboard" onMouseClicked="#handleNavTeacherDashboard" styleClass="sidebar-item">
            <children><Label text="🏠  Tableau de bord" /></children>
         </HBox>
         <HBox fx:id="navTeacherSaisie" onMouseClicked="#handleNavSaisieNotes" styleClass="sidebar-item">
            <children><Label text="✏️  Saisie des Notes" /></children>
         </HBox>
         <HBox fx:id="navTeacherMesEtudiants" onMouseClicked="#handleNavTeacherMesEtudiants" styleClass="sidebar-item">
            <children><Label text="👥  Mes Étudiants" /></children>
         </HBox>

         <!-- Student items -->
         <HBox fx:id="navStudentBulletin" onMouseClicked="#handleNavStudentBulletin" styleClass="sidebar-item">
            <children><Label text="📄  Mon Bulletin" /></children>
         </HBox>
         <HBox fx:id="navStudentNotes" onMouseClicked="#handleNavStudentNotes" styleClass="sidebar-item">
            <children><Label text="📝  Mes Notes" /></children>
         </HBox>

         <Region VBox.vgrow="ALWAYS" /> <!-- Pousse le bouton déconnexion en bas -->
         
         <HBox onMouseClicked="#handleLogout" spacing="10.0" styleClass="sidebar-item">
            <children>
               <Label styleClass="text-gold" text="🚪  Déconnexion" />
            </children>
         </HBox>
      </VBox>

      <!-- Profile components (Hidden but must exist for Controller) -->
      <Circle fx:id="userAvatar" visible="false" managed="false" />
      <Label fx:id="userRoleLabel" visible="false" managed="false" />
      <Label fx:id="userNameLabel" visible="false" managed="false" />
   </children>
   <padding>
      <Insets bottom="20.0" />
   </padding>
</VBox>
