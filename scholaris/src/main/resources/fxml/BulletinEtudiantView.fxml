<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16.0" style="-fx-padding: 24;" styleClass="bg-page" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.BulletinEtudiantController">
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox>
                    <children>
                        <Label styleClass="page-title" text="Mon Bulletin" />
                        <Label styleClass="text-muted" text="Consultez et téléchargez votre bulletin de notes" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="trimestreCombo" prefWidth="180.0" promptText="Trimestre I" />
                <Region prefWidth="12.0" />
                <Button onAction="#handleTelecharger" styleClass="btn-primary" text="↓ Télécharger mon bulletin" />
            </children>
        </HBox>

        <!-- APERÇU CARTE -->
        <VBox styleClass="card">
            <children>
                <!-- EN-TÊTE NAVY -->
                <VBox spacing="10.0" style="-fx-padding: 20; -fx-background-color: #0D1B4B; -fx-background-radius: 8 8 0 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label style="-fx-font-size: 11; -fx-font-weight: bold;" styleClass="text-white" text="IP NET INSTITUTE OF TECHNOLOGY — RÉPUBLIQUE TOGOLAISE" />
                                        <Label style="-fx-font-size: 18; -fx-font-weight: bold;" styleClass="text-white" text="Bulletin de Notes" />
                                        <Label style="-fx-font-size: 12;" styleClass="text-faint" text="Année scolaire 2025-2026" />
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Rectangle arcHeight="6.0" arcWidth="6.0" fill="WHITE" height="40.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="40.0" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- INFOS ÉLÈVE -->
                <HBox spacing="24.0" style="-fx-padding: 16;">
                    <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="input-label" text="ÉLÈVE" />
                                <Label fx:id="lblNomComplet" style="-fx-font-weight: bold; -fx-font-size: 14;" styleClass="text-navy" text="-" />
                                <Label fx:id="lblMatricule" style="-fx-font-size: 12;" styleClass="text-muted" text="-" />
                            </children>
                        </VBox>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="input-label" text="CLASSE" />
                                <Label fx:id="lblClasse" style="-fx-font-weight: bold; -fx-font-size: 14;" styleClass="text-navy" text="-" />
                                <Label fx:id="lblPeriode" style="-fx-font-size: 12;" styleClass="text-muted" text="-" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- RÉSUMÉ NOTES -->
                <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 16; -fx-background-color: #F8F9FA;">
                    <children>
                        <HBox alignment="BASELINE_LEFT" spacing="8.0">
                            <children>
                                <Label fx:id="lblMoyGeneral" style="-fx-font-size: 24; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                                <Label style="-fx-font-size: 14;" styleClass="text-muted" text="/20" />
                            </children>
                        </HBox>
                        <Label fx:id="lblAppGeneral" styleClass="badge-blue" text="-" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblRang" styleClass="text-muted" text="Rang : -" />
                        <Label fx:id="lblTrimestreBadge" styleClass="badge-blue" text="Trimestre 1" />
                    </children>
                </HBox>

                <!-- TABLEAU NOTES -->
                <TableView fx:id="bulletinTable" prefHeight="400.0" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colMatiere" prefWidth="250.0" text="MATIÈRE" />
                        <TableColumn fx:id="colNote" prefWidth="100.0" text="NOTE" />
                        <TableColumn fx:id="colMoyClasse" prefWidth="120.0" text="MOY. CLASSE" />
                        <TableColumn fx:id="colApp" prefWidth="150.0" text="APPRÉCIATION" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
