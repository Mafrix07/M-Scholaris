<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-padding: 30;" styleClass="bg-page" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.EtudiantController">
   <children>
      <!-- HEADER AVEC ACTIONS -->
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <VBox>
               <children>
                  <Label styleClass="h1" text="Gestion des Étudiants" />
                  <Label styleClass="text-muted" text="Liste complète et inscriptions" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleAjouter" styleClass="btn-refresh" text="+ Inscrire un étudiant" />
         </children>
      </HBox>

      <!-- BARRE DE RECHERCHE ET FILTRES -->
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card" style="-fx-padding: 15;">
         <children>
            <TextField fx:id="searchField" promptText="🔍 Rechercher par nom, matricule..." HBox.hgrow="ALWAYS" minWidth="250.0" />
            <ComboBox fx:id="classeFilter" prefWidth="180.0" promptText="Filtrer par classe" />
            <ComboBox fx:id="niveauFilter" prefWidth="150.0" promptText="Niveau" />
            <Button styleClass="btn-refresh" text="Filtrer" />
         </children>
      </HBox>

      <!-- TABLEAU DES ÉTUDIANTS : Remplit tout l'espace vertical -->
      <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
         <children>
            <TableView fx:id="etudiantTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colMatricule" minWidth="100.0" prefWidth="120.0" text="MATRICULE" />
                  <TableColumn fx:id="colNom" minWidth="200.0" prefWidth="300.0" text="NOM COMPLET" />
                  <TableColumn fx:id="colDate" minWidth="120.0" prefWidth="150.0" text="DATE NAISSANCE" />
                  <TableColumn fx:id="colClasse" minWidth="100.0" prefWidth="120.0" text="CLASSE" />
                  <TableColumn fx:id="colMoyenne" minWidth="80.0" prefWidth="100.0" text="MOYENNE" />
                  <TableColumn fx:id="colActions" minWidth="130.0" prefWidth="150.0" text="ACTIONS" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            
            <!-- PAGINATION / FOOTER -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 15;">
               <children>
                  <Label fx:id="lblPagination" styleClass="text-muted" text="Affichage de 1-10 sur 150" />
                  <HBox fx:id="pageButtons" spacing="5.0">
                     <children>
                        <Button onAction="#handlePrevPage" text="&lt;" />
                        <Button onAction="#handleNextPage" text="&gt;" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
