<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Region?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" style="-fx-padding: 24;" styleClass="bg-page" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.SaisieNotesController">
   <children>
      <!-- HEADER -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
               <children>
                  <Label styleClass="h1" text="Saisie des notes" />
                  <Label fx:id="lblRoleBadge" styleClass="badge-blue" text="Enseignant" />
               </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleEnregistrerTout" styleClass="primary-button" text="Enregistrer toutes les notes" />
         </children>
      </HBox>

      <!-- SÉLECTEURS + KPI -->
      <HBox alignment="CENTER_LEFT" spacing="12.0">
         <children>
            <ComboBox fx:id="classeCombo" prefWidth="150.0" promptText="Classe" />
            <ComboBox fx:id="matiereCombo" prefWidth="150.0" promptText="Matière" />
            <ComboBox fx:id="trimestreCombo" prefWidth="150.0" promptText="Trimestre" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
               <children>
                  <Label styleClass="label-tag" text="MOY. DE CLASSE" />
                  <HBox alignment="BASELINE_LEFT" spacing="2.0">
                     <children>
                        <Label fx:id="lblMoyenneClasse" style="-fx-font-size: 24; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                        <Label styleClass="text-muted" text="/20" />
                     </children>
                  </HBox>
                  <Label fx:id="lblInfoClasse" style="-fx-font-size: 11;" styleClass="text-muted" text="Sélectionnez une classe" />
               </children>
            </VBox>
         </children>
      </HBox>

      <!-- TABLEAU -->
      <TableView fx:id="notesTable" styleClass="table-view" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colMatricule" prefWidth="100.0" text="MATRICULE" />
            <TableColumn fx:id="colNom" prefWidth="250.0" text="NOM COMPLET" />
            <TableColumn fx:id="colNote" prefWidth="150.0" text="NOTE /20" />
            <TableColumn fx:id="colAppreciation" prefWidth="130.0" text="APPRÉCIATION" />
            <TableColumn fx:id="colRang" prefWidth="80.0" text="RANG" />
            <TableColumn fx:id="colAction" prefWidth="120.0" text="ACTION" />
         </columns>
      </TableView>

      <!-- RÉSUMÉ -->
      <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 12;" styleClass="bg-off-white">
         <children>
            <Label styleClass="label-tag" text="RÉSUMÉ DE LA SAISIE" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblMoyResume" style="-fx-font-weight: bold;" text="Moyenne : -" />
            <Label fx:id="lblAppResume" styleClass="badge-blue" text="-" />
            <Label fx:id="lblContexteResume" styleClass="text-muted" text="Aucune donnée" />
         </children>
      </HBox>

      <!-- ACTIONS FINALES -->
      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button onAction="#handleAnnuler" styleClass="secondary-button" text="Annuler les modifications" />
            <Button onAction="#handleEnregistrerTout" styleClass="primary-button" text="Enregistrer tout" />
         </children>
      </HBox>
   </children>
</VBox>
