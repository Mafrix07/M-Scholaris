<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootPane" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.MainLayoutController">
   <left>
      <fx:include fx:id="sidebar" source="Sidebar.fxml" />
   </left>
   <center>
      <VBox styleClass="bg-page">
         <children>
            <!-- HEADER : S'adapte à la largeur du centre -->
            <HBox alignment="CENTER_LEFT" minHeight="70.0" prefHeight="70.0" styleClass="header-bar">
               <children>
                  <Label styleClass="h1" text="Espace Administration" />
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="userNameLabel" styleClass="user-name" text="Chargement..." />
                              <Label fx:id="userRoleLabel" styleClass="user-role" text="RÔLE" />
                           </children>
                        </VBox>
                        <Circle fx:id="userAvatar" fill="#C9A84C" radius="20.0" stroke="TRANSPARENT" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets left="30.0" right="30.0" />
               </padding>
            </HBox>
            
            <!-- CONTENU DYNAMIQUE : Remplit tout l'espace restant -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
   </center>
</BorderPane>
