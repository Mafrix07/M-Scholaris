<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" styleClass="bg-page" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.DashboardAdminViewController">
   <content>
      <VBox spacing="20.0" style="-fx-padding: 24;">
         <children>
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="h1" text="Tableau de bord" />
                        <Label styleClass="text-muted" text="Trimestre I · 2025-2026" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="badge-blue" text="Administrateur" />
                  <Button onAction="#handleRefresh" styleClass="secondary-button" text="↻" />
               </children>
            </HBox>

            <!-- KPI ROW -->
            <HBox spacing="16.0">
               <children>
                  <!-- KPI 1: Étudiants -->
                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox>
                           <children>
                              <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-blue-pale">
                                 <children><Label styleClass="text-blue" text="👥" /></children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label fx:id="lblEtudiants" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="ÉTUDIANTS INSCRITS" />
                        <Label styleClass="badge-blue" text="+2.5% vs T3" />
                     </children>
                  </VBox>

                  <!-- KPI 2: Classes -->
                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox>
                           <children>
                              <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-green-pale">
                                 <children><Label style="-fx-text-fill: #2E8B57;" text="🏠" /></children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label fx:id="lblClasses" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="CLASSES ACTIVES" />
                        <Label styleClass="badge-green" text="Stable" />
                     </children>
                  </VBox>

                  <!-- KPI 3: Moyenne -->
                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox>
                           <children>
                              <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-gold-pale">
                                 <children><Label styleClass="text-gold" text="📈" /></children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label fx:id="lblMoyenne" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                        <Label styleClass="text-muted" text="MOYENNE GÉNÉRALE" />
                        <Label styleClass="badge-gold" text="Tendance ↑" />
                     </children>
                  </VBox>

                  <!-- KPI 4: Difficulté -->
                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox>
                           <children>
                              <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-red-pale">
                                 <children><Label styleClass="text-error" text="⚠️" /></children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label fx:id="lblDifficulte" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="ÉLÈVES EN DIFFICULTÉ" />
                        <Label styleClass="badge-red" text="Urgent" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- PANNEAUX ROW -->
            <HBox spacing="16.0">
               <children>
                  <!-- Répartition par classe -->
                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label style="-fx-font-weight: bold;" text="Répartition par classe" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Hyperlink onAction="#handleVoirClasses" styleClass="text-blue" text="Voir tout →" />
                           </children>
                        </HBox>
                        <VBox fx:id="classesContainer" spacing="12.0" />
                     </children>
                  </VBox>

                  <!-- Bulletins récents -->
                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label style="-fx-font-weight: bold;" text="Bulletins récents" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Hyperlink onAction="#handleVoirBulletins" styleClass="text-blue" text="Tout voir →" />
                           </children>
                        </HBox>
                        <VBox fx:id="bulletinsContainer" spacing="8.0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
