<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<!--
    Login.fxml — Scholaris School Management App
    Charte graphique : Navy #0D2A5A | Or #B8963E | Blanc cassé #F5F5F5
    Toutes les couleurs et styles passent par scholaris.css
-->

<HBox
    maxHeight="-Infinity"
    maxWidth="-Infinity"
    minHeight="-Infinity"
    minWidth="-Infinity"
    prefHeight="700.0"
    prefWidth="1000.0"
    stylesheets="@../css/style.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.scholaris.controller.LoginController">

    <children>

        <!-- ================================================================
             PANNEAU GAUCHE — Bleu Marine (présentation de l'app)
             ================================================================ -->
        <VBox prefWidth="340.0" styleClass="sidebar">
            <children>

                <!-- Logo + Nom de l'application -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@../images/Logo.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="sidebar-app-name" text="SCHOLARIS" />
                    </children>
                    <VBox.margin>
                        <Insets left="40.0" top="40.0" />
                    </VBox.margin>
                </HBox>

                <!-- Sous-titre en or -->
                <Label styleClass="sidebar-app-subtitle" text="SCHOOL MANAGEMENT APP">
                    <VBox.margin>
                        <Insets left="40.0" top="6.0" />
                    </VBox.margin>
                </Label>

                <!-- Slogan central -->
                <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                    <children>
                        <TextFlow textAlignment="CENTER">
                            <children>
                                <Text styleClass="text-white" strokeType="OUTSIDE" strokeWidth="0.0"
                                      text="Gérez votre établissement ">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Text>
                                <Text styleClass="text-gold" strokeType="OUTSIDE" strokeWidth="0.0"
                                      text="intelligemment.">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Text>
                            </children>
                            <VBox.margin>
                                <Insets left="32.0" right="32.0" />
                            </VBox.margin>
                        </TextFlow>

                        <!-- Description -->
                        <Label
                            styleClass="text-caption"
                            text="La plateforme tout-en-un pour centraliser vos étudiants, notes, bulletins et statistiques de réussite."
                            textAlignment="CENTER"
                            wrapText="true">
                            <VBox.margin>
                                <Insets left="40.0" right="40.0" top="16.0" />
                            </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <!-- Statistiques en bas du panneau -->
                <HBox alignment="CENTER" spacing="24.0">
                    <children>

                        <!-- Stat : Étudiants -->
                        <VBox alignment="CENTER" spacing="2.0">
                            <children>
                                <Label styleClass="text-gold, h2" text="248" />
                                <Label styleClass="sidebar-section-label" text="ÉTUDIANTS" />
                            </children>
                        </VBox>

                        <!-- Séparateur vertical -->
                        <Region prefWidth="1.0" prefHeight="40.0" styleClass="bg-navy-mid" />

                        <!-- Stat : Classes -->
                        <VBox alignment="CENTER" spacing="2.0">
                            <children>
                                <Label styleClass="text-gold, h2" text="12" />
                                <Label styleClass="sidebar-section-label" text="CLASSES" />
                            </children>
                        </VBox>

                        <!-- Séparateur vertical -->
                        <Region prefWidth="1.0" prefHeight="40.0" styleClass="bg-navy-mid" />

                        <!-- Stat : Digitalisé -->
                        <VBox alignment="CENTER" spacing="2.0">
                            <children>
                                <Label styleClass="text-gold, h2" text="100%" />
                                <Label styleClass="sidebar-section-label" text="DIGITALISÉ" />
                            </children>
                        </VBox>

                    </children>
                    <VBox.margin>
                        <Insets bottom="40.0" />
                    </VBox.margin>
                </HBox>

            </children>
        </VBox>

        <!-- ================================================================
             PANNEAU DROIT — Formulaire de connexion
             ================================================================ -->
        <VBox alignment="CENTER" styleClass="bg-off-white" HBox.hgrow="ALWAYS">
            <children>

                <!-- Carte de connexion -->
                <VBox fx:id="loginCard" maxWidth="380.0" spacing="20.0" styleClass="card">
                    <children>

                        <!-- En-tête de la carte -->
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="h2" text="Connexion" />
                                <Label styleClass="text-caption" text="Bienvenue sur le portail Scholaris" />
                            </children>
                        </VBox>

                        <!-- Séparateur -->
                        <Separator styleClass="separator" prefWidth="200.0" />

                        <!-- Champ : Email -->
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="label-tag" text="ADRESSE EMAIL" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="text-field">
                                    <children>
                                        <Label styleClass="text-secondary" text="✉" />
                                        <TextField
                                            fx:id="emailField"
                                            promptText="Entrez votre adresse email"
                                            style="-fx-background-color: transparent; -fx-padding: 0;"
                                            HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Champ : Mot de passe -->
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="label-tag" text="MOT DE PASSE" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="text-field">
                                    <children>
                                        <Label styleClass="text-secondary" text="🔒" />
                                        <StackPane HBox.hgrow="ALWAYS">
                                            <children>
                                                <PasswordField
                                                    fx:id="passwordField"
                                                    promptText="••••••••"
                                                    style="-fx-background-color: transparent; -fx-padding: 0;" />
                                                <TextField
                                                    fx:id="passwordVisibleField"
                                                    promptText="••••••••"
                                                    style="-fx-background-color: transparent; -fx-padding: 0;"
                                                    visible="false" />
                                            </children>
                                        </StackPane>
                                        <Button
                                            fx:id="togglePasswordBtn"
                                            mnemonicParsing="false"
                                            onAction="#handleTogglePassword"
                                            styleClass="outline-button"
                                            text="👁" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Bouton connexion + message d'erreur -->
                        <VBox alignment="CENTER" spacing="8.0">
                            <children>
                                <Button
                                    maxWidth="1.7976931348623157E308"
                                    mnemonicParsing="false"
                                    onAction="#handleLogin"
                                    prefHeight="45.0"
                                    styleClass="primary-button"
                                    text="Se connecter →" />
                                <Label
                                    fx:id="errorLabel"
                                    styleClass="alert-error"
                                    text="Identifiant ou mot de passe incorrect."
                                    visible="false" />
                            </children>
                        </VBox>

                        <!-- Lien support -->
                        <HBox alignment="CENTER">
                            <children>
                                <Button
                                    mnemonicParsing="false"
                                    onAction="#handleSupport"
                                    styleClass="outline-button"
                                    text="Besoin d'aide ? Contacter le support">
                                    <font><Font size="12.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <Separator styleClass="separator" prefWidth="200.0" />

                        <!-- Lien Inscription -->
                        <HBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label styleClass="text-caption" text="Pas encore de compte ?" />
                                <Button
                                    mnemonicParsing="false"
                                    onAction="#handleGoToSignup"
                                    styleClass="btn-text-blue"
                                    text="S'inscrire" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>

    </children>
</HBox>
