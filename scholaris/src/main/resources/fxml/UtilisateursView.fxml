<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" style="-fx-padding: 30;" styleClass="bg-page" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.UtilisateursController">
   <children>
      <!-- HEADER -->
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <VBox>
               <children>
                  <Label styleClass="h1" text="Gestion des Utilisateurs" />
                  <Label styleClass="text-muted" text="Comptes accès et administration" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleCreer" styleClass="btn-refresh" text="+ Nouvel utilisateur" />
         </children>
      </HBox>

      <!-- TABLEAU DES UTILISATEURS -->
      <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
         <children>
            <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colId" minWidth="50.0" prefWidth="60.0" text="ID" />
                  <TableColumn fx:id="colNomComplet" minWidth="150.0" prefWidth="250.0" text="UTILISATEUR" />
                  <TableColumn fx:id="colEmail" minWidth="180.0" prefWidth="250.0" text="ADRESSE EMAIL" />
                  <TableColumn fx:id="colRole" minWidth="100.0" prefWidth="150.0" text="RÔLE ACCÈS" />
                  <TableColumn fx:id="colDate" minWidth="130.0" prefWidth="180.0" text="DATE CRÉATION" />
                  <TableColumn fx:id="colActions" minWidth="200.0" prefWidth="300.0" text="ACTIONS" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
