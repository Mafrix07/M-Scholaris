<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<SplitPane dividerPositions="0.25" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.BulletinController">
  <items>
    <!-- GAUCHE: Liste des étudiants (Taille fixe minimale recommandée) -->
    <VBox minWidth="250.0" spacing="12.0" style="-fx-background-color: white; -fx-padding: 20;">
         <children>
            <Label style="-fx-font-weight: bold;" styleClass="text-navy" text="ÉTUDIANTS" />
            <TextField fx:id="searchEtudiant" promptText="🔍 Rechercher..." />
            <ListView fx:id="etudiantListView" VBox.vgrow="ALWAYS" />
         </children>
    </VBox>

    <!-- DROITE: Aperçu bulletin (S'étire 100%) -->
    <VBox spacing="16.0" style="-fx-padding: 30;" styleClass="bg-page">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <VBox>
                     <children>
                        <Label fx:id="lblNomEtudiant" style="-fx-font-weight: bold; -fx-font-size: 18;" styleClass="text-navy" text="Sélectionnez un étudiant" />
                        <Label fx:id="lblInfoEtudiant" styleClass="text-muted" text="Informations détaillées" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleGenererPDF" styleClass="btn-refresh" text="↓ Exporter en PDF" />
               </children>
            </HBox>

            <!-- APERÇU CARTE RESPONSIVE -->
            <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0; -fx-overflow-x: hidden;">
               <children>
                  <!-- EN-TÊTE -->
                  <VBox spacing="10.0" style="-fx-padding: 25; -fx-background-color: #1B2A6B; -fx-background-radius: 10 10 0 0;">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="4.0">
                                 <children>
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);" text="IP NET INSTITUTE OF TECHNOLOGY" />
                                    <Label style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" text="Bulletin de Notes Officiel" />
                                    <Label style="-fx-font-size: 12; -fx-text-fill: #C9A84C;" text="Année scolaire 2025-2026" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Rectangle fill="WHITE" height="45.0" width="45.0" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- INFOS ÉLÈVE -->
                  <HBox spacing="20.0" style="-fx-padding: 20;">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="kpi-label" text="IDENTITÉ DE L'ÉLÈVE" />
                              <Label fx:id="lblNomComplet" style="-fx-font-weight: bold; -fx-font-size: 15;" styleClass="text-navy" text="-" />
                              <Label fx:id="lblMatricule" styleClass="text-muted" text="-" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="kpi-label" text="CLASSE &amp; PÉRIODE" />
                              <Label fx:id="lblClasse" style="-fx-font-weight: bold; -fx-font-size: 15;" styleClass="text-navy" text="-" />
                              <Label fx:id="lblPeriode" styleClass="text-muted" text="-" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- RÉSUMÉ NOTES -->
                  <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-padding: 15 20; -fx-background-color: #F9FAFF;">
                     <children>
                        <HBox alignment="BASELINE_LEFT" spacing="5.0">
                           <children>
                              <Label fx:id="lblMoyGeneral" style="-fx-font-size: 26; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                              <Label styleClass="text-muted" text="/20" />
                           </children>
                        </HBox>
                        <Label fx:id="lblAppGeneral" styleClass="badge-blue" text="-" />
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="lblRang" style="-fx-font-weight: bold;" styleClass="text-navy" text="Rang : -" />
                              <Label fx:id="lblTrimestre" styleClass="badge-gold" text="Trimestre 1" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- TABLEAU NOTES : Remplit l'espace restant dans la carte -->
                  <TableView fx:id="bulletinTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colMatiere" minWidth="150.0" prefWidth="250.0" text="MATIÈRE" />
                        <TableColumn fx:id="colNote" minWidth="80.0" prefWidth="100.0" text="MOYENNE" />
                        <TableColumn fx:id="colMoyClasse" minWidth="100.0" prefWidth="120.0" text="MOY. CLASSE" />
                        <TableColumn fx:id="colApp" minWidth="150.0" prefWidth="150.0" text="APPRÉCIATION" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
    </VBox>
  </items>
</SplitPane>
