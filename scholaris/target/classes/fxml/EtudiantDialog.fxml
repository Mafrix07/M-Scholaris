<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Region?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="480.0" spacing="16.0" styleClass="card" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.EtudiantDialogController">
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label fx:id="lblTitle" style="-fx-font-weight: bold; -fx-font-size: 18;" text="Ajouter / Modifier un étudiant" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleClose" styleClass="secondary-button" text="✕" />
         </children>
      </HBox>

      <VBox spacing="6.0">
         <children>
            <Label styleClass="label-tag" text="MATRICULE" />
            <TextField fx:id="fieldMatricule" promptText="Saisir le matricule" styleClass="text-field" />
         </children>
      </VBox>

      <HBox spacing="12.0">
         <children>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="label-tag" text="NOM" />
                  <TextField fx:id="fieldNom" promptText="Nom de l'étudiant" styleClass="text-field" />
               </children>
            </VBox>
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="label-tag" text="PRÉNOM" />
                  <TextField fx:id="fieldPrenom" promptText="Prénom de l'étudiant" styleClass="text-field" />
               </children>
            </VBox>
         </children>
      </HBox>

      <VBox spacing="6.0">
         <children>
            <Label styleClass="label-tag" text="EMAIL" />
            <TextField fx:id="fieldEmail" promptText="exemple@ecole.com" styleClass="text-field" />
         </children>
      </VBox>

      <VBox spacing="6.0">
         <children>
            <Label styleClass="label-tag" text="DATE DE NAISSANCE" />
            <DatePicker fx:id="fieldDateNaissance" maxWidth="Infinity" styleClass="text-field" />
         </children>
      </VBox>

      <VBox spacing="6.0">
         <children>
            <Label styleClass="label-tag" text="CLASSE" />
            <ComboBox fx:id="fieldClasse" maxWidth="Infinity" promptText="Choisir une classe" styleClass="text-field" />
         </children>
      </VBox>

      <HBox alignment="CENTER_RIGHT" spacing="12.0">
         <children>
            <Button onAction="#handleClose" styleClass="secondary-button" text="Annuler" />
            <Button onAction="#handleEnregistrer" styleClass="primary-button" text="Enregistrer" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
   </padding>
</VBox>
