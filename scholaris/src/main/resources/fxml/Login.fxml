<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.LoginController">
   <children>
      <!-- Gauche: Branding -->
      <VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" styleClass="bg-primary" stylesheets="@../css/style.css" HBox.hgrow="ALWAYS">
         <children>
            <ImageView fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/Logo.png" />
               </image>
            </ImageView>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Scholaris">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Text>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Gérez votre établissement avec simplicité">
               <font>
                  <Font size="18.0" />
               </font>
            </Text>
         </children>
      </VBox>
      
      <!-- Droite: Formulaire -->
      <VBox alignment="CENTER" prefWidth="500.0" spacing="25.0" style="-fx-background-color: white;" stylesheets="@../css/style.css">
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Connexion">
               <font>
                  <Font name="System Bold" size="28.0" />
               </font>
            </Text>
            
            <VBox spacing="10.0">
               <children>
                  <Label text="Email" />
                  <TextField fx:id="emailField" prefHeight="40.0" promptText="exemple@email.com" />
               </children>
            </VBox>
            
            <VBox spacing="10.0">
               <children>
                  <Label text="Mot de passe" />
                  <HBox spacing="5.0">
                     <children>
                        <PasswordField fx:id="passwordField" prefHeight="40.0" HBox.hgrow="ALWAYS" />
                        <Button fx:id="togglePasswordBtn" mnemonicParsing="false" onAction="#handleTogglePassword" prefHeight="40.0" text="👁" />
                     </children>
                  </HBox>
                  <TextField fx:id="passwordVisibleField" managed="false" prefHeight="40.0" visible="false" />
               </children>
            </VBox>
            
            <Label fx:id="errorLabel" textFill="RED" visible="false" wrapText="true" />
            
            <Button fx:id="loginBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" styleClass="button-primary" text="Se connecter" />
            
            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Pas encore de compte ?" />
                  <Hyperlink onAction="#handleGoToSignup" styleClass="button-link" text="S'inscrire" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>
