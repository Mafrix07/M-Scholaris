<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" style="-fx-padding: 24;" styleClass="bg-page" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.UtilisateursController">
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label styleClass="page-title" text="Gestion des utilisateurs" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleCreer" styleClass="btn-primary" text="+ Créer un utilisateur" />
            </children>
        </HBox>

        <TableView fx:id="userTable" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colEmail" prefWidth="200.0" text="USERNAME / EMAIL" />
                <TableColumn fx:id="colNomComplet" prefWidth="200.0" text="NOM COMPLET" />
                <TableColumn fx:id="colRole" prefWidth="120.0" text="RÔLE" />
                <TableColumn fx:id="colDate" prefWidth="150.0" text="CRÉÉ LE" />
                <TableColumn fx:id="colActions" prefWidth="250.0" text="ACTIONS" />
            </columns>
        </TableView>
    </children>
</VBox>
