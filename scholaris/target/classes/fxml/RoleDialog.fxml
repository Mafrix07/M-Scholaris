<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="420.0" spacing="16.0" style="-fx-padding: 32;" styleClass="card" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.RoleDialogController">
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Modifier le rôle" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleClose" styleClass="btn-text-blue" text="✕" />
            </children>
        </HBox>

        <Label fx:id="lblUsername" styleClass="text-muted" text="Utilisateur : -" />

        <HBox alignment="CENTER_LEFT" spacing="8.0">
            <children>
                <Label styleClass="text-muted" text="Rôle actuel :" />
                <Label fx:id="lblRoleActuel" styleClass="badge-blue" text="-" />
            </children>
        </HBox>

        <VBox spacing="4.0">
            <children>
                <Label styleClass="input-label" text="NOUVEAU RÔLE" />
                <ComboBox fx:id="roleCombo" maxWidth="Infinity" />
            </children>
        </VBox>

        <VBox fx:id="classesSection" managed="false" spacing="4.0" visible="false">
            <children>
                <Label styleClass="input-label" text="CLASSES ASSIGNÉES" />
                <ListView fx:id="classesList" prefHeight="150.0" />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <children>
                <Button onAction="#handleClose" styleClass="btn-secondary" text="Annuler" />
                <Button onAction="#handleEnregistrer" styleClass="btn-primary" text="Enregistrer" />
            </children>
        </HBox>
    </children>
</VBox>
