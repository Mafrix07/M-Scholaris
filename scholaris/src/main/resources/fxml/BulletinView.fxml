<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<SplitPane dividerPositions="0.28" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.BulletinController">
  <items>
    <!-- GAUCHE: Liste des étudiants -->
    <VBox spacing="12.0" style="-fx-background-color: white; -fx-padding: 16;">
         <children>
            <Label style="-fx-font-weight: bold;" styleClass="text-navy" text="Étudiants" />
            <TextField fx:id="searchEtudiant" promptText="Rechercher..." styleClass="text-field" />
            <ListView fx:id="etudiantListView" VBox.vgrow="ALWAYS" />
         </children>
    </VBox>

    <!-- DROITE: Aperçu bulletin -->
    <VBox spacing="16.0" style="-fx-padding: 24;" styleClass="bg-page">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <VBox>
                     <children>
                        <Label fx:id="lblNomEtudiant" style="-fx-font-weight: bold; -fx-font-size: 16;" styleClass="text-navy" text="Sélectionnez un étudiant" />
                        <Label fx:id="lblInfoEtudiant" styleClass="text-muted" text="Informations détaillées" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleGenererPDF" styleClass="primary-button" text="↓ Générer le PDF" />
               </children>
            </HBox>

            <!-- APERÇU CARTE -->
            <VBox styleClass="card">
               <children>
                  <!-- EN-TÊTE NAVY -->
                  <VBox spacing="10.0" style="-fx-padding: 20;" styleClass="sidebar">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="4.0">
                                 <children>
                                    <Label style="-fx-font-size: 11; -fx-font-weight: bold;" styleClass="text-white" text="IP NET INSTITUTE OF TECHNOLOGY — RÉPUBLIQUE TOGOLAISE" />
                                    <Label style="-fx-font-size: 18; -fx-font-weight: bold;" styleClass="text-white" text="Bulletin de Notes" />
                                    <Label style="-fx-font-size: 12;" styleClass="text-faint" text="Année scolaire 2025-2026" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Rectangle arcHeight="6.0" arcWidth="6.0" fill="WHITE" height="40.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="40.0" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- INFOS ÉLÈVE -->
                  <HBox spacing="24.0" style="-fx-padding: 16;">
                     <children>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="label-tag" text="ÉLÈVE" />
                              <Label fx:id="lblNomComplet" style="-fx-font-weight: bold; -fx-font-size: 14;" styleClass="text-navy" text="-" />
                              <Label fx:id="lblMatricule" style="-fx-font-size: 12;" styleClass="text-muted" text="-" />
                           </children>
                        </VBox>
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="label-tag" text="CLASSE" />
                              <Label fx:id="lblClasse" style="-fx-font-weight: bold; -fx-font-size: 14;" styleClass="text-navy" text="-" />
                              <Label fx:id="lblPeriode" style="-fx-font-size: 12;" styleClass="text-muted" text="-" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <!-- RÉSUMÉ NOTES -->
                  <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 16;" styleClass="bg-off-white">
                     <children>
                        <HBox alignment="BASELINE_LEFT" spacing="8.0">
                           <children>
                              <Label fx:id="lblMoyGeneral" style="-fx-font-size: 24; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                              <Label style="-fx-font-size: 14;" styleClass="text-muted" text="/20" />
                           </children>
                        </HBox>
                        <Label fx:id="lblAppGeneral" styleClass="badge-blue" text="-" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblRang" styleClass="text-muted" text="Rang : -" />
                        <Label fx:id="lblTrimestre" styleClass="badge-blue" text="Trimestre 1" />
                     </children>
                  </HBox>

                  <!-- TABLEAU NOTES -->
                  <TableView fx:id="bulletinTable" prefHeight="300.0" styleClass="table-view">
                     <columns>
                        <TableColumn fx:id="colMatiere" prefWidth="250.0" text="MATIÈRE" />
                        <TableColumn fx:id="colNote" prefWidth="100.0" text="NOTE" />
                        <TableColumn fx:id="colMoyClasse" prefWidth="120.0" text="MOY. CLASSE" />
                        <TableColumn fx:id="colApp" prefWidth="150.0" text="APPRÉCIATION" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
    </VBox>
  </items>
</SplitPane>
