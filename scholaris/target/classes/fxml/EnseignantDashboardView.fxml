<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" styleClass="bg-page" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.EnseignantDashboardController">
   <content>
      <VBox spacing="20.0" style="-fx-padding: 24;">
         <children>
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="h1" text="Espace Enseignant" />
                        <Label styleClass="text-muted" text="Bonjour, prêt pour la saisie des notes ?" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="badge-blue" text="Enseignant" />
               </children>
            </HBox>

            <!-- KPI ROW -->
            <HBox spacing="16.0">
               <children>
                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-blue-pale">
                           <children><Label styleClass="text-blue" text="👥" /></children>
                        </VBox>
                        <Label fx:id="lblMesEtudiants" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="MES ÉTUDIANTS" />
                     </children>
                  </VBox>

                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-green-pale">
                           <children><Label style="-fx-text-fill: #2E8B57;" text="📖" /></children>
                        </VBox>
                        <Label fx:id="lblMesMatieres" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="MATIÈRES ASSIGNÉES" />
                     </children>
                  </VBox>

                  <VBox spacing="10.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-gold-pale">
                           <children><Label styleClass="text-gold" text="📊" /></children>
                        </VBox>
                        <Label fx:id="lblMaMoyenne" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                        <Label styleClass="text-muted" text="MOYENNE MES CLASSES" />
                     </children>
                  </VBox>

                  <VBox onMouseClicked="#handleVoirNotesAttente" spacing="10.0" style="-fx-cursor: hand;" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <VBox alignment="CENTER" prefHeight="40.0" prefWidth="40.0" style="-fx-background-radius: 8;" styleClass="bg-orange-pale">
                           <children><Label style="-fx-text-fill: #B8963E;" text="⏳" /></children>
                        </VBox>
                        <Label fx:id="lblEnAttente" style="-fx-font-size: 32; -fx-font-weight: bold;" styleClass="text-navy" text="0" />
                        <Label styleClass="text-muted" text="NOTES EN ATTENTE" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- PANNEAUX ROW -->
            <HBox spacing="16.0">
               <children>
                  <!-- Mes classes -->
                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Mes classes &amp; Progressions" />
                        <VBox fx:id="mesClassesContainer" spacing="12.0" />
                     </children>
                  </VBox>

                  <!-- Activité récente -->
                  <VBox spacing="15.0" styleClass="card" prefWidth="350.0">
                     <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Activité récente" />
                        <VBox fx:id="activiteContainer" spacing="10.0" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- Tableau élèves en difficulté -->
            <VBox spacing="15.0" styleClass="card">
               <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0" /></padding>
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Élèves en difficulté" />
                        <Region prefWidth="10.0" />
                        <Label styleClass="badge-red" text="&lt; 10/20" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink styleClass="text-blue" text="Voir tout →" />
                     </children>
                  </HBox>
                  <TableView fx:id="difficultesTable" prefHeight="200.0" styleClass="table-view">
                     <columns>
                        <TableColumn fx:id="colMatricule" prefWidth="100.0" text="MATRICULE" />
                        <TableColumn fx:id="colNom" prefWidth="250.0" text="NOM" />
                        <TableColumn fx:id="colClasse" prefWidth="120.0" text="CLASSE" />
                        <TableColumn fx:id="colMatiere" prefWidth="150.0" text="MATIÈRE" />
                        <TableColumn fx:id="colNote" prefWidth="80.0" text="NOTE" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
