<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToHeight="true" fitToWidth="true" styleClass="scroll-pane" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.DashboardAdminViewController">
   <content>
      <VBox spacing="30.0" style="-fx-padding: 30;">
         <children>
            <!-- HEADER : Titre + Bouton rafraîchir -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #4A4A6A;" text="APERÇU RAPIDE" />
                        <Label styleClass="text-muted" text="Résumé de l'activité scolaire" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleRefresh" styleClass="btn-refresh" text="↻ Actualiser les données" />
               </children>
            </HBox>

            <!-- KPI CARDS : S'étirent proportionnellement -->
            <HBox spacing="20.0">
               <children>
                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <VBox alignment="CENTER" styleClass="icon-box, bg-blue-pale">
                                 <children><Label style="-fx-font-size: 24;" text="👥" /></children>
                              </VBox>
                              <VBox>
                                 <children>
                                    <Label styleClass="kpi-label" text="ÉTUDIANTS" />
                                    <Label fx:id="lblEtudiants" styleClass="kpi-value" text="0" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label styleClass="badge-blue" text="+12 nouveaux inscrits" />
                     </children>
                  </VBox>

                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <VBox alignment="CENTER" styleClass="icon-box, bg-green-pale">
                                 <children><Label style="-fx-font-size: 24;" text="🏠" /></children>
                              </VBox>
                              <VBox>
                                 <children>
                                    <Label styleClass="kpi-label" text="CLASSES" />
                                    <Label fx:id="lblClasses" styleClass="kpi-value" text="0" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label styleClass="badge-green" text="100% opérationnelles" />
                     </children>
                  </VBox>

                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <VBox alignment="CENTER" styleClass="icon-box, bg-gold-pale">
                                 <children><Label style="-fx-font-size: 24;" text="📈" /></children>
                              </VBox>
                              <VBox>
                                 <children>
                                    <Label styleClass="kpi-label" text="MOYENNE" />
                                    <Label fx:id="lblMoyenne" styleClass="kpi-value" text="0.00" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label styleClass="badge-gold" text="Tendance en hausse" />
                     </children>
                  </VBox>

                  <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <VBox alignment="CENTER" styleClass="icon-box, bg-red-pale">
                                 <children><Label style="-fx-font-size: 24;" text="⚠️" /></children>
                              </VBox>
                              <VBox>
                                 <children>
                                    <Label styleClass="kpi-label" text="ALERTES" />
                                    <Label fx:id="lblDifficulte" styleClass="kpi-value" text="0" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Label styleClass="badge-red" text="Suivi pédagogique requis" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- PANELS SECONDAIRES : S'étirent horizontalement et verticalement -->
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Répartition des Étudiants" textFill="#1B2A6B" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Hyperlink onAction="#handleVoirClasses" styleClass="text-blue" text="Détails →" />
                           </children>
                        </HBox>
                        <VBox fx:id="classesContainer" spacing="12.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>

                  <VBox spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label style="-fx-font-size: 18; -fx-font-weight: bold;" text="Activité des Bulletins" textFill="#1B2A6B" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Hyperlink onAction="#handleVoirBulletins" styleClass="text-blue" text="Gérer →" />
                           </children>
                        </HBox>
                        <VBox fx:id="bulletinsContainer" spacing="10.0" VBox.vgrow="ALWAYS" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
