<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16.0" style="-fx-padding: 24;" styleClass="bg-page" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.SaisieNotesController">
   <children>
      <!-- HEADER AVEC BOUTON ENREGISTRER -->
      <HBox alignment="CENTER_LEFT" spacing="10.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="8.0">
               <children>
                  <Label styleClass="h1" text="Saisie des notes" />
                  <Label fx:id="lblRoleBadge" styleClass="badge-blue" text="Enseignant" />
               </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleEnregistrerTout" styleClass="btn-refresh" text="Enregistrer tout" />
         </children>
      </HBox>

      <!-- SÉLECTEURS ET KPI DYNAMIQUES -->
      <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="card" style="-fx-padding: 15;">
         <children>
            <ComboBox fx:id="classeCombo" prefWidth="180.0" promptText="Choisir une classe" />
            <ComboBox fx:id="matiereCombo" prefWidth="180.0" promptText="Choisir une matière" />
            <ComboBox fx:id="trimestreCombo" prefWidth="150.0" promptText="Trimestre" />
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT">
               <children>
                  <Label styleClass="kpi-label" text="MOY. DE CLASSE" />
                  <HBox alignment="BASELINE_RIGHT" spacing="2.0">
                     <children>
                        <Label fx:id="lblMoyenneClasse" style="-fx-font-size: 24; -fx-font-weight: bold;" styleClass="text-navy" text="0.00" />
                        <Label styleClass="text-muted" text="/20" />
                     </children>
                  </HBox>
                  <Label fx:id="lblInfoClasse" style="-fx-font-size: 11;" styleClass="text-muted" text="Sélectionnez une classe" />
               </children>
            </VBox>
         </children>
      </HBox>

      <!-- TABLEAU DE SAISIE : S'étire verticalement -->
      <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
         <children>
            <TableView fx:id="notesTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colMatricule" minWidth="90.0" prefWidth="100.0" text="MATRICULE" />
                  <TableColumn fx:id="colNom" minWidth="200.0" prefWidth="250.0" text="NOM COMPLET" />
                  <TableColumn fx:id="colNote" minWidth="100.0" prefWidth="120.0" text="NOTE /20" />
                  <TableColumn fx:id="colAppreciation" minWidth="150.0" prefWidth="150.0" text="APPRÉCIATION" />
                  <TableColumn fx:id="colRang" minWidth="70.0" prefWidth="80.0" text="RANG" />
                  <TableColumn fx:id="colAction" minWidth="110.0" prefWidth="120.0" text="ACTION" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>

      <!-- RÉSUMÉ ET ACTIONS FINALES -->
      <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-padding: 15;" styleClass="card">
         <children>
            <Label styleClass="kpi-label" text="RÉSUMÉ" />
            <Label fx:id="lblMoyResume" style="-fx-font-weight: bold;" text="Moyenne : -" />
            <Label fx:id="lblAppResume" styleClass="badge-blue" text="-" />
            <Label fx:id="lblContexteResume" styleClass="text-muted" text="Aucune donnée" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleAnnuler" style="-fx-background-color: transparent; -fx-text-fill: #E74C3C;" text="Annuler tout" />
            <Button onAction="#handleEnregistrerTout" styleClass="btn-refresh" text="Valider la saisie" />
         </children>
      </HBox>
   </children>
</VBox>
