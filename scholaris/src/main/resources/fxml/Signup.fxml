<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.scholaris.controller.SignupController">
   <children>
      <!-- Gauche: Branding -->
      <VBox alignment="CENTER" prefWidth="400.0" spacing="20.0" styleClass="bg-primary" stylesheets="@../css/style.css" HBox.hgrow="ALWAYS">
         <children>
            <ImageView fitHeight="120.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/Logo.png" />
               </image>
            </ImageView>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Scholaris">
               <font>
                  <Font name="System Bold" size="48.0" />
               </font>
            </Text>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Rejoignez votre établissement">
               <font>
                  <Font size="18.0" />
               </font>
            </Text>
         </children>
      </VBox>
      
      <!-- Droite: Formulaire -->
      <ScrollPane fitToWidth="true" prefWidth="600.0" style="-fx-background-color: white;">
         <content>
            <VBox alignment="TOP_CENTER" spacing="20.0" style="-fx-background-color: white;" stylesheets="@../css/style.css">
               <padding>
                  <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
               </padding>
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Créer un compte étudiant">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Text>
                  
                  <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                      <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                      <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Nom" />
                              <TextField fx:id="nomField" prefHeight="35.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1">
                           <children>
                              <Label text="Prénom" />
                              <TextField fx:id="prenomField" prefHeight="35.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.rowIndex="1">
                           <children>
                              <Label text="Email" />
                              <TextField fx:id="emailField" prefHeight="35.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                           <children>
                              <Label text="Matricule" />
                              <TextField fx:id="matriculeField" prefHeight="35.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.rowIndex="2">
                           <children>
                              <Label text="Classe" />
                              <ComboBox fx:id="classeCombo" maxWidth="1.7976931348623157E308" prefHeight="35.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                           <children>
                              <Label text="Date de Naissance" />
                              <DatePicker fx:id="dateNaissancePicker" maxWidth="1.7976931348623157E308" prefHeight="35.0" />
                           </children>
                        </VBox>
                     </children>
                  </GridPane>
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Mot de passe" />
                        <PasswordField fx:id="passwordField" prefHeight="35.0" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0">
                     <children>
                        <Label text="Confirmer le mot de passe" />
                        <PasswordField fx:id="confirmPasswordField" prefHeight="35.0" />
                     </children>
                  </VBox>
                  
                  <Label fx:id="messageLabel" textAlignment="CENTER" visible="false" wrapText="true" />
                  
                  <Button fx:id="signupBtn" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSignup" styleClass="button-primary" text="Créer mon compte" />
                  
                  <HBox alignment="CENTER" spacing="5.0">
                     <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Déjà un compte ?" />
                        <Hyperlink onAction="#handleGoToLogin" styleClass="button-link" text="Se connecter" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </children>
</HBox>
